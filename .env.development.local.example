# ============================================================================
# 🚀 КОПИРУЙТЕ ЭТОТ ФАЙЛ В .env.development.local И ЗАПОЛНИТЕ ЗНАЧЕНИЯ
# ============================================================================
#
# Инструкция:
# 1. cp .env.development.local.example .env.development.local
# 2. Откройте .env.development.local и замените VALUE на реальные значения
# 3. Запустите: pnpm setup
#

# ============================================================================
# 🗄️ Database Configuration (ОБЯЗАТЕЛЬНО!)
# ============================================================================

# PostgreSQL connection string
# Получите эту строку:
# - Если используете Neon: https://console.neon.tech → Connection string
# - Если используете AWS RDS: RDS console → Databases → Connectivity
# - Если используете локальную БД: postgresql://user:password@localhost:5432/dbname
#
# Формат: postgresql://[user[:password]@][host][:port][/dbname][?param=value]
#
# Пример Neon:
#   postgresql://neondb_owner:AbCdEf123xyz@ep-morning-block-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# Пример локально:
#   postgresql://postgres:password@localhost:5432/mydb
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ============================================================================
# 🤖 AI Configuration (ОБЯЗАТЕЛЬНО!)
# ============================================================================

# OpenAI API Key
# Получите на: https://platform.openai.com/api-keys
# Начинается с "sk-"
OPENAI_API_KEY="sk-..."

# ============================================================================
# 🔐 Better Auth Configuration (ОБЯЗАТЕЛЬНО!)
# ============================================================================

# Secret key для подписи сессий
# Сгенерируйте командой: openssl rand -base64 32
# ВАЖНО: Используйте разные значения для разных окружений (dev/prod)!
BETTER_AUTH_SECRET="your_secret_key_here_generated_with_openssl"

# ============================================================================
# 🌐 Application URLs (ОПЦИОНАЛЬНО для локальной разработки)
# ============================================================================

# Обычно не требуется устанавливать для localhost разработки
# NEXT_PUBLIC_API_URL="http://localhost:3000"

# ============================================================================
# ⚠️ ВАЖНО!
# ============================================================================
#
# 1. Никогда не коммитьте этот файл в git!
#    Добавьте в .gitignore: .env.development.local
#
# 2. Не делитесь .env.development.local с другими людьми!
#    Каждый должен создать свой с личными credentials
#
# 3. После заполнения файла запустите:
#    pnpm setup
#
# 4. Если что-то не работает, проверьте:
#    - DATABASE_URL точно скопирована (включая спецсимволы в пароле)
#    - OPENAI_API_KEY действителен
#    - BETTER_AUTH_SECRET достаточно длинный и случайный
